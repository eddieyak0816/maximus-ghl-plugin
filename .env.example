# GHL Plugin Environment Variables
# Copy this to .env and fill in your values. Never commit .env — it contains secrets.

# ============================================================================
# Node.js
# ============================================================================
NODE_ENV=development
PORT=3000

# ============================================================================
# GoHighLevel (GHL) — Required for Phase 2
# ============================================================================
# Get these from your GHL account
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-location-id

# Example: If you have 4 Eddie entries in GHL, list their IDs here
# (Phase 2 will read these to determine who's available)
# GHL_TEAM_MEMBER_IDS=user_id_1,user_id_2,user_id_3,user_id_4
